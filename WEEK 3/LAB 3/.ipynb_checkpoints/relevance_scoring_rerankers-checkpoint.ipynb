    "print(f\"{'Rank':<6} {'Baseline ID':<20} {'Cross-Enc ID':<22} {'Change?'}\")\n",
    "print(\"-\" * 60)\n",
    "for rank, (b, c) in enumerate(zip(base_ids, cross_ids), 1):\n",
    "    label = \"same\" if b == c else \"RERANKED\"\n",
    "    print(f\"{rank:<6} {b:<20} {c:<22} {label}\")\n",
    "\n",
    "promoted = set(cross_ids) - set(base_ids)\n",
    "demoted  = set(base_ids)  - set(cross_ids)\n",
    "print(f\"\\nPromoted into top-5 by cross-encoder : {promoted or 'none'}\")\n",
    "print(f\"Demoted out of top-5 by cross-encoder: {demoted  or 'none'}\")"
