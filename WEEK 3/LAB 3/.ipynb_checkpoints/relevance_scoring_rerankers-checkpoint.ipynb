    "cross_pool  = cross_encoder_rerank(shift_query, [dict(r) for r in pool], top_n=10)\n",
    "\n",
    "base_ids  = [r[\"id\"] for r in pool[:5]]\n",
    "cross_ids = [r[\"id\"] for r in cross_pool[:5]]\n",
